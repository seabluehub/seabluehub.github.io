---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getArchiveTree, getPublishedPostViews } from '../../../../data/posts';

export async function getStaticPaths() {
  const posts = getPublishedPostViews(await getCollection('posts'));
  const archiveTree = getArchiveTree(posts);
  return Object.entries(archiveTree).flatMap(([year, months]) =>
    Object.entries(months).map(([month, posts]) => ({
      params: { year, month },
      props: { posts },
    }))
  );
}

const { year, month } = Astro.params;
const { posts } = Astro.props;
---

<BaseLayout title={`${year} 年 ${month} 月归档`}>
  <section class="timeline">
    <h1 class="timeline-title">{year} 年 {month} 月归档</h1>
    {posts.map((post) => (
      <div class="timeline-item">
        <time>{post.date}</time>
        <a href={post.url}>{post.title}</a>
      </div>
    ))}
  </section>
</BaseLayout>
