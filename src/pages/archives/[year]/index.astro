---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getArchiveTree, getPublishedPostViews } from '../../../data/posts';

export async function getStaticPaths() {
  const posts = getPublishedPostViews(await getCollection('posts'));
  const archiveTree = getArchiveTree(posts);
  return Object.keys(archiveTree).map((year) => ({
    params: { year },
    props: { months: archiveTree[year] },
  }));
}

const { year } = Astro.params;
const { months } = Astro.props;
---

<BaseLayout title={`${year} 年归档`}>
  <section class="timeline">
    <h1 class="timeline-title">{year} 年归档</h1>
    {Object.keys(months).sort((a, b) => Number(b) - Number(a)).map((month) => (
      <>
        <h2 class="timeline-subtitle">
          <a href={`/archives/${year}/${month}/`}>{month} 月</a>
        </h2>
        {months[month].map((post) => (
          <div class="timeline-item">
            <time>{post.date}</time>
            <a href={post.url}>{post.title}</a>
          </div>
        ))}
      </>
    ))}
  </section>
</BaseLayout>
